# APEX Gateway Configuration Template
# Copy this file to .env and fill in your actual values.

# 1. Initia Network Settings
INITIA_LCD_URL=https://lcd.testnet.initia.xyz
INITIA_CHAIN_ID=initiation-1

# 2. Gateway Security (The account that triggers 'settle_call')
# WARNING: Use a fresh testnet account. Do not use your main wallet!
GATEWAY_MNEMONIC="your twelve word seed phrase goes here between these quotes"

# 3. Contract Information
# The address where your settlement.move module is deployed
APEX_CONTRACT_ADDRESS="0x..."

# 4. Server Configuration
PORT=3000
NODE_ENV=development
